# Production Environment Variables for AWS Deployment

# Backend API URL - Points to API Gateway custom domain
REACT_APP_API_URL=https://api.oussemaamri.com

# Instructions for AWS Deployment:
# 1. Create Lambda function (portfolio-chatbot-api)
# 2. Create API Gateway HTTP API
# 3. Configure custom domain: api.oussemaamri.com
# 4. This URL is also set in GitHub Actions workflow

# Alternative (if using Render for backend):
# REACT_APP_API_URL=https://portfolio-api.onrender.com/api

